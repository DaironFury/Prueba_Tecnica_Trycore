# =====================================================================
# EVM Dashboard — variables de entorno raíz para docker-compose
# =====================================================================
# Copia este archivo a `.env` (mismo directorio que docker-compose.yml).
# Compose lo carga automáticamente. NUNCA commits el `.env` real.
# =====================================================================

# --- Base de datos ------------------------------------------------------
POSTGRES_DB=evm_db
POSTGRES_USER=evm_user
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_PORT=5432

# --- API ----------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
API_PORT=8000

# --- Frontend -----------------------------------------------------------
FRONTEND_PORT=3000

# Lista de orígenes CORS permitidos, separados por coma.
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

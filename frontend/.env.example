# =====================================================================
# EVM Dashboard — frontend environment variables
# =====================================================================
# Only variables prefixed with VITE_ are exposed to the client.
# =====================================================================

# Where the Vite dev server should proxy /api requests.
# In Docker the proxy target is the backend service name; on bare metal
# it is localhost. Application code uses relative URLs, so this only
# matters when running `npm run dev` outside Docker.
VITE_API_PROXY_TARGET=http://localhost:8000

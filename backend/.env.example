# =====================================================================
# EVM Dashboard — variables de entorno del backend
# =====================================================================
# Copia este archivo a `.env` y ajusta los valores para tu entorno.
# El archivo `.env` NUNCA debe commitearse en el repositorio.
# =====================================================================

# Aplicación
APP_NAME=EVM Dashboard API
APP_ENV=development
LOG_LEVEL=INFO

# Base de datos
# Cuando se ejecuta FUERA de Docker (Postgres local en el host):
#   DATABASE_URL=postgresql+asyncpg://evm_user:evm_pass@localhost:5432/evm_db
#
# Cuando se ejecuta DENTRO de Docker (docker-compose):
#   DATABASE_URL=postgresql+asyncpg://evm_user:evm_pass@database:5432/evm_db
#
# El segmento de host debe coincidir con el nombre del servicio en docker-compose, NO localhost.
DATABASE_URL=postgresql+asyncpg://evm_user:evm_pass@database:5432/evm_db

# CORS — lista de orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# Servidor
HOST=0.0.0.0
PORT=8000
